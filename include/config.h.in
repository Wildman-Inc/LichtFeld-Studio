#pragma once

// Build configuration generated by CMake
#ifndef CUDA_GL_INTEROP_ENABLED
#cmakedefine CUDA_GL_INTEROP_ENABLED
#endif

// GPU Backend configuration
#cmakedefine USE_CUDA @USE_CUDA@
#cmakedefine USE_HIP @USE_HIP@
#cmakedefine USE_ROCM @USE_ROCM@

// Version information
#define PROJECT_VERSION_MAJOR @PROJECT_VERSION_MAJOR @
#define PROJECT_VERSION_MINOR @PROJECT_VERSION_MINOR @
#define PROJECT_VERSION_PATCH @PROJECT_VERSION_PATCH @

// Git commit information
#define GIT_COMMIT_HASH_SHORT "@GIT_COMMIT_HASH_SHORT@"
#define GIT_TAGGED_VERSION  "@GIT_TAGGED_VERSION@"

// Build type
#cmakedefine DEBUG_BUILD
#cmakedefine RELEASE_BUILD

// Platform detection
#if defined(_WIN32) || defined(_WIN64)
#define PLATFORM_WINDOWS
#elif defined(__linux__)
#define PLATFORM_LINUX
#else
#define PLATFORM_UNKNOWN
#endif

// GPU Backend detection at runtime
#if defined(__HIP_PLATFORM_AMD__) || defined(__HIPCC__) || USE_HIP
    #define GPU_BACKEND_HIP 1
    #define GPU_BACKEND_CUDA 0
    #define GPU_BACKEND_NAME "ROCm/HIP"
#elif defined(__CUDACC__) || defined(CUDA_VERSION) || USE_CUDA
    #define GPU_BACKEND_HIP 0
    #define GPU_BACKEND_CUDA 1
    #define GPU_BACKEND_NAME "CUDA"
#else
    #define GPU_BACKEND_HIP 0
    #define GPU_BACKEND_CUDA 0
    #define GPU_BACKEND_NAME "None"
#endif

// Feature flags
#ifdef CUDA_GL_INTEROP_ENABLED
#define USE_CUDA_GL_INTEROP 1
#define INTEROP_AVAILABLE   true
#else
#define USE_CUDA_GL_INTEROP 0
#define INTEROP_AVAILABLE   false
#endif